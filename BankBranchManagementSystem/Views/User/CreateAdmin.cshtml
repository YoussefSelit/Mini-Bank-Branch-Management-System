@model BankBranchManagementSystem.ViewModels.CreateAdminAccountViewModel

@{
    ViewData["Title"] = "Add Admin";
}

<div class="d-flex justify-content-center mt-4">
    <div class="card shadow-lg border-0" style="width:100%; max-width:700px; border-radius:15px;">

        <div class="card-header bg-dark text-white text-center py-3">
            <h2 class="mb-0">Add Admin</h2>
        </div>

        <div class="card-body p-4">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            <form asp-controller="User" asp-action="CreateAdmin" method="post">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row mb-3">

                    <div class="col">
                        <label asp-for="UserFirstName" class="form-label fw-semibold"></label>
                        <input asp-for="UserFirstName" class="form-control" />
                        <span asp-validation-for="UserFirstName" class="text-danger"></span>
                    </div>

                    <div class="col">
                        <label asp-for="UserLastName" class="form-label fw-semibold"></label>
                        <input asp-for="UserLastName" class="form-control" />
                        <span asp-validation-for="UserLastName" class="text-danger"></span>
                    </div>

                </div>

                <div class="row mb-3">

                    <div class="col">
                        <label asp-for="UserPassword" class="form-label fw-semibold"></label>
                        <input asp-for="UserPassword" class="form-control" type="password" />
                        <span asp-validation-for="UserPassword" class="text-danger"></span>
                    </div>

                    <div class="col">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                </div>

                <div class="row mb-3">

                    <div class="col">
                        <label asp-for="UserEmail" class="form-label fw-semibold"></label>
                        <input asp-for="UserEmail" class="form-control" type="email" />
                        <span asp-validation-for="UserEmail" class="text-danger"></span>
                    </div>

                    <div class="col">
                        <label asp-for="UserPhoneNumber" class="form-label fw-semibold"></label>
                        <input asp-for="UserPhoneNumber" class="form-control" type="tel" />
                        <span asp-validation-for="UserPhoneNumber" class="text-danger"></span>
                    </div>

                </div>

                <div class="form-text mb-3">
                    The username will be generated automatically (e.g. admin2, admin3, ...).
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">

                    <a asp-controller="User"
                       asp-action="Profile"
                       class="btn btn-dark px-4">
                        Cancel
                    </a>

                    <button type="submit"
                            class="btn btn-danger px-4">
                        Add Admin
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}