@model BankBranchManagementSystem.Models.PagedResult<BankBranchManagementSystem.Dtos.EmployeeListDto>

@{
    ViewData["Title"] = "Employee Management";

    bool isAdmin = User.IsInRole("Admin");
    bool isBranchManagerUser = User.IsInRole("Branch Manager");
    string activeAction = string.IsNullOrWhiteSpace(Model.SearchTerm) ? "Index" : "Search";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Employee Management</h1>

    <a asp-controller="Employee" asp-action="Create" class="btn btn-danger">
        + Add Employee
    </a>
</div>

<form asp-controller="Employee"
      asp-action="Search"
      method="get"
      class="d-flex mb-4"
      style="max-width:400px;">

    <input type="text"
           name="searchTerm"
           class="form-control me-2"
           placeholder="Search by name or ID..."
           value="@Model.SearchTerm" />

    <button type="submit" class="btn btn-outline-secondary">
        Search
    </button>
</form>

<div class="card shadow-sm">
    <table class="table table-striped mb-0 align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Job Title</th>
                <th>Branch</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>

        <tbody>

            @if (!Model.Items.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">
                        No employees found.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var employee in Model.Items)
                {
                    bool branchIsActive = employee.EmployeeBranchStatus == "Active";
                    bool employeeIsBranchManager =
                        employee.EmployeeBranchManagerId == employee.EmployeeId;
                    <tr>

                        <td>
                            <a href="#"
                               class="view-employee-link text-dark text-decoration-none fw-semibold"
                               data-employee-id="@employee.EmployeeId">
                                @employee.EmployeeFirstName @employee.EmployeeLastName
                            </a>
                        </td>

                        <td>
                            @(employee.EmployeeJobTitle ?? "-")
                        </td>

                        <td>
                            @(employee.EmployeeBranchName ?? "-")
                        </td>

                        <td>
                            <span class="badge @(employee.EmploymentStatus == "Active"
                                                                                                    ? "bg-success"
                                                                                                    : "bg-secondary")">

                                @(employee.EmploymentStatus ?? "-")

                            </span>
                        </td>

                        <td class="text-end">

                            @* EDIT *@
                            @if (employeeIsBranchManager && isBranchManagerUser)
                            {
                                <button type="button"
                                        class="btn btn-sm btn-outline-dark"
                                        disabled
                                        title="Branch managers cannot edit another branch manager.">
                                    Edit
                                </button>
                            }
                            else
                            {
                                <a asp-controller="Employee"
                                   asp-action="Edit"
                                   asp-route-id="@employee.EmployeeId"
                                   class="btn btn-sm btn-outline-dark">
                                    Edit
                                </a>
                            }

                            @* TRANSFER *@
                            @if (branchIsActive)
                            {
                                @if (employeeIsBranchManager && isBranchManagerUser)
                                {
                                    <button type="button"
                                            class="btn btn-sm btn btn-sm btn-outline-secondary"
                                            disabled
                                            title="Branch managers cannot transfer another branch manager.">
                                        Transfer
                                    </button>
                                }
                                else
                                {
                                    <a asp-controller="Employee"
                                       asp-action="Transfer"
                                       asp-route-id="@employee.EmployeeId"
                                       class="btn btn-sm btn btn-sm btn-outline-secondary">
                                        Transfer
                                    </a>
                                }
                            }
                            else
                            {
                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary"
                                        disabled
                                        title="Cannot transfer: current branch is inactive">
                                    Transfer
                                </button>
                            }

                            @* DELETE *@
                            @if (employeeIsBranchManager && isBranchManagerUser)
                            {
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        disabled
                                        title="Branch managers cannot delete another branch manager.">
                                    Delete
                                </button>
                            }
                            else
                            {
                                <a asp-controller="Employee"
                                   asp-action="Delete"
                                   asp-route-id="@employee.EmployeeId"
                                   class="btn btn-sm btn-outline-danger">
                                    Delete
                                </a>
                            }

                        </td>

                    </tr>
                }
            }

        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3" aria-label="Employee pagination">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link"
                   asp-controller="Employee"
                   asp-action="@activeAction"
                   asp-route-searchTerm="@Model.SearchTerm"
                   asp-route-pageNumber="@(Model.PageNumber - 1)">Previous</a>
            </li>

            @foreach (var pageNum in Model.GetPageNumbers())
            {
                if (pageNum == null)
                {
                    <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                }
                else
                {
                    <li class="page-item @(pageNum == Model.PageNumber ? "active" : "")">
                        <a class="page-link"
                           asp-controller="Employee"
                           asp-action="@activeAction"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-pageNumber="@pageNum">@pageNum</a>
                    </li>
                }
            }

            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link"
                   asp-controller="Employee"
                   asp-action="@activeAction"
                   asp-route-searchTerm="@Model.SearchTerm"
                   asp-route-pageNumber="@(Model.PageNumber + 1)">Next</a>
            </li>
        </ul>
    </nav>
}

<!-- View Employee modal -->
<<!-- View Employee modal -->
    <div class="modal fade" id="viewEmployeeModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-body" id="viewEmployeeModalBody">
                    <div class="text-center py-4">
                        <div class="spinner-border text-dark" role="status"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

@section Scripts {
    <script>

        console.log("Employee script loaded");


        (function () {

            var modalEl = document.getElementById('viewEmployeeModal');
            var modalBody = document.getElementById('viewEmployeeModalBody');

            var modal = new bootstrap.Modal(modalEl);


            document.querySelectorAll('.view-employee-link').forEach(function (link) {

                link.addEventListener('click', function (e) {

                    e.preventDefault();


                    var employeeId = this.getAttribute('data-employee-id');


                    console.log("Employee ID:", employeeId);


                    modalBody.innerHTML =
                        '<div class="text-center py-4"><div class="spinner-border text-dark"></div></div>';


                    modal.show();


                    fetch('/Employee/ViewModal/' + employeeId)

                        .then(function(response) {

                            if (!response.ok) {
                                throw new Error();
                            }

                            return response.text();

                        })

                        .then(function(html) {

                            modalBody.innerHTML = html;

                        })

                        .catch(function() {

                            modalBody.innerHTML =
                            '<div class="alert alert-danger">Could not load employee details.</div>';

                        });

                });

            });


        })();

    </script>
}