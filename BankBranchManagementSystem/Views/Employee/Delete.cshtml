@model BankBranchManagementSystem.Dtos.EmployeeDetailsDto

@{
    ViewData["Title"] = "Delete Employee";
    bool isBranchManager = ViewBag.IsBranchManager ?? false;
}

<div class="d-flex justify-content-center mt-4">
    <div class="card shadow-sm" style="max-width:550px; width:100%;">

        <div class="card-header bg-dark text-white">
            <h3 class="mb-0">Delete Employee</h3>
        </div>

        <div class="card-body">

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <p class="mb-4">
                Are you sure you want to delete
                <strong>@Model.EmployeeFirstName @Model.EmployeeLastName</strong>?
            </p>

            @if (isBranchManager)
            {
                <div class="alert alert-warning">
                    <strong>This employee is currently the Branch Manager.</strong>
                    <hr />

                    Deleting this employee will:

                    <ul class="mb-0 mt-2">
                        <li>Delete the employee record.</li>
                        <li>Delete the linked user account.</li>
                        <li>Remove them as the Branch Manager.</li>
                    </ul>

                    <div class="mt-3">
                        The branch will have <strong>no assigned manager</strong> until a new one is selected from the
                        <strong>Branch Information</strong> page.
                    </div>
                </div>
            }

            <form asp-controller="Employee"
                  asp-action="Delete"
                  asp-route-id="@Model.EmployeeId"
                  method="post">

                @Html.AntiForgeryToken()

                <div class="text-end">

                    <a asp-controller="Employee"
                       asp-action="Index"
                       class="btn btn-outline-dark">
                        Cancel
                    </a>

                    <button type="submit"
                            class="btn btn-danger">
                        Delete Employee
                    </button>

                </div>

            </form>

        </div>

    </div>
</div>