@model IEnumerable<BankBranchManagementSystem.Dtos.BranchListDto>
@{
    ViewData["Title"] = "Branch Management";
    bool isAdmin = User.IsInRole("Administrator") || User.IsInRole("Admin");
    var canDelete = ViewBag.CanDelete as Dictionary<int, bool> ?? new Dictionary<int, bool>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Branch Management</h1>

    @if (isAdmin)
    {
        <a asp-controller="Branch" asp-action="Create" class="btn btn-danger">+ Add Branch</a>
    }
    else
    {
        <button type="button" class="btn btn-danger" disabled title="Only administrators can add branches">
            + Add Branch
        </button>
    }
</div>

<form asp-controller="Branch" asp-action="Search" method="get" class="d-flex mb-4" style="max-width: 400px;">
    <input type="text" name="searchTerm" class="form-control me-2" placeholder="Search by name or code..." value="@Context.Request.Query["searchTerm"]" />
    <button type="submit" class="btn btn-outline-secondary">Search</button>
</form>

<div class="card shadow-sm">
    <table class="table table-striped mb-0 align-middle">
        <thead>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>City</th>
                <th>Manager</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-muted text-center py-4">No branches found.</td></tr>
            }
            else
            {
                @foreach (var branch in Model)
                {
                    var isActive = branch.BranchStatus == "Active";
                    var branchCanDelete = canDelete.TryGetValue(branch.BranchId, out var val) && val;

                    <tr>
                        <td>@branch.BranchCode</td>
                        <td>
                            <a href="#" class="view-branch-link text-dark text-decoration-none fw-semibold" data-branch-id="@branch.BranchId">
                                @branch.BranchName
                            </a>
                        </td>
                        <td>@(branch.BranchCity ?? "-")</td>
                        <td>@(branch.BranchManagerName ?? "-")</td>
                        <td>
                            <span class="badge @(isActive ? "bg-success" : "bg-secondary")">
                                @(branch.BranchStatus ?? "-")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-controller="Branch" asp-action="Edit" asp-route-id="@branch.BranchId"
                               class="btn btn-sm btn-outline-dark">Edit</a>

                            @if (isActive)
                            {
                                <form asp-controller="Branch" asp-action="Deactivate" asp-route-id="@branch.BranchId" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-warning">Deactivate</button>
                                </form>
                            }
                            else
                            {
                                <form asp-controller="Branch" asp-action="Activate" asp-route-id="@branch.BranchId" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-success">Activate</button>
                                </form>
                            }

                            @if (isAdmin)
                            {
                                @if (branchCanDelete)
                                {
                                    <a asp-controller="Branch" asp-action="Delete" asp-route-id="@branch.BranchId"
                                       class="btn btn-sm btn-outline-danger">Delete</a>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-outline-danger" disabled
                                            title="Cannot delete: branch has active employees">
                                        Delete
                                    </button>
                                }
                            }
                            else
                            {
                                <button type="button" class="btn btn-sm btn-outline-danger" disabled title="Only administrators can delete branches">Delete</button>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- View Branch modal shell: body gets filled in via JS from /Branch/ViewModal/{id} -->
<div class="modal fade" id="viewBranchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body" id="viewBranchModalBody">
                <div class="text-center py-4">
                    <div class="spinner-border text-dark" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const modal = new bootstrap.Modal(document.getElementById("viewBranchModal"));
            const body = document.getElementById("viewBranchModalBody");

            document.querySelectorAll(".view-branch-link").forEach(function (link) {

                link.onclick = function (e) {

                    e.preventDefault();

                    const id = this.dataset.branchId;


                    fetch("/Branch/ViewModal/" + id)
                        .then(function (response) {


                            return response.text();
                        })
                        .then(function (html) {
                           console.log(html);


                                    body.innerHTML = html;


        modal.show();


                        })
                        .catch(function (err) {

                            alert(err);

                        });

                };

            });

        });
    </script>
}