@model BankBranchManagementSystem.Dtos.BranchDetailsDto

<div class="view-branch-container11 p-3">
    <h5 class="mb-3">BRANCH DETAILS</h5>

    <div class="d-flex justify-content-between border-bottom py-2">
        <span class="fw-semibold">Branch Name</span>
        <span>@Model.BranchName</span>
    </div>

    <div class="d-flex justify-content-between border-bottom py-2">
        <span class="fw-semibold">Branch Code</span>
        <span>@Model.BranchCode</span>
    </div>

    <div class="d-flex justify-content-between border-bottom py-2">
        <span class="fw-semibold">Address</span>
        <span>@(Model.BranchAddress ?? "-")</span>
    </div>

    <div class="d-flex justify-content-between border-bottom py-2">
        <span class="fw-semibold">City</span>
        <span>@(Model.BranchCity ?? "-")</span>
    </div>

    <div class="d-flex justify-content-between border-bottom py-2">
        <span class="fw-semibold">Phone</span>
        <span>@(Model.BranchPhone ?? "-")</span>
    </div>

    <div class="d-flex justify-content-between border-bottom py-2">
        <span class="fw-semibold">Email</span>
        <span>@(Model.BranchEmail ?? "-")</span>
    </div>

    <div class="d-flex justify-content-between border-bottom py-2">
        <span class="fw-semibold">Branch Manager</span>
        <span>
            @(Model.BranchManagerName ?? "-No assigned manager-")
        </span>
    </div>

    <div class="d-flex justify-content-between border-bottom py-2">
        <span class="fw-semibold">Opening Date</span>
        <span>@(Model.BranchOpeningDate?.ToString("yyyy-MM-dd") ?? "-")</span>
    </div>

    <div class="d-flex justify-content-between py-2">
        <span class="fw-semibold">Status</span>
        <span class="badge @(Model.BranchStatus == "Active" ? "bg-success" : "bg-secondary")">
            @(Model.BranchStatus ?? "-")
        </span>
    </div>

    <!-- Accordion: expandable list of employees at this branch -->
    <div class="accordion mt-3" id="branchEmployeesAccordion">
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#branchEmployeesCollapse">
                    Employees (@Model.Employees.Count)
                </button>
            </h2>

            <div id="branchEmployeesCollapse"
                 class="accordion-collapse collapse"
                 data-bs-parent="#branchEmployeesAccordion">

                <div class="accordion-body p-0">

                    @if (Model.Employees.Count == 0)
                    {
                        <p class="text-muted p-3 mb-0">
                            No employees at this branch.
                        </p>
                    }
                    else
                    {
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Job Title</th>
                                    <th>Status</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var employee in Model.Employees)
                                {
                                    <tr>
                                        <td>@employee.FullName</td>

                                        <td>@(employee.EmployeeJobTitle ?? "-")</td>

                                        <td>
                                            <span class="badge @(employee.EmploymentStatus == "Active" ? "bg-success" : "bg-secondary")">
                                                @(employee.EmploymentStatus ?? "-")
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                </div>
            </div>
        </div>
    </div>

    <div class="text-center mt-3">
        <button type="button"
                class="btn btn-danger"
                data-bs-dismiss="modal">
            CLOSE
        </button>
    </div>
</div>