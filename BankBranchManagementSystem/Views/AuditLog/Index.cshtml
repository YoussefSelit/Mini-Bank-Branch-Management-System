@model IEnumerable<BankBranchManagementSystem.Dtos.AuditLogDto>

@{
    ViewData["Title"] = "Audit Logs";
}

<h2 class="mb-4">Audit Logs</h2>

<div class="card shadow-sm">
    <table class="table table-striped mb-0">
        <thead class="table-dark">
            <tr>
                <th>Date</th>
                <th>User</th>
                <th>Action</th>
                <th>Entity</th>
                <th>Employee</th>
                <th>Branch</th>
            </tr>
        </thead>

        <tbody>

        @foreach (var log in Model.OrderByDescending(x => x.ActionDate))
        {
            <tr>
                <td>@log.ActionDate</td>
                <td>@(log.UserUsername ?? "System")</td>
                <td>@log.Action</td>
                <td>@log.EntityName</td>
                <td>@(log.EmployeeFullName ?? (log.EmployeeId.HasValue ? $"#{log.EmployeeId}" : "-"))</td>
                <td>@(log.BranchName ?? (log.BranchId.HasValue ? $"#{log.BranchId}" : "-"))</td>
            </tr>
        }

        </tbody>
    </table>
</div>