@model IEnumerable<BankBranchManagementSystem.Models.AuditLog>

@{
    ViewData["Title"] = "Audit Logs";
}

<h2 class="mb-4">Audit Logs</h2>

<div class="card shadow-sm">
    <table class="table table-striped mb-0">
        <thead class="table-dark">
            <tr>
                <th>Date</th>
                <th>User</th>
                <th>Action</th>
                <th>Entity</th>
                <th>Employee ID</th>
                <th>Branch ID</th>
            </tr>
        </thead>

        <tbody>

        @foreach (var log in Model.OrderByDescending(x => x.ActionDate))
        {
            <tr>
                <td>@log.ActionDate</td>
                <td>@($"{log.User?.UserFirstName} {log.User?.UserLastName}")</td>
                <td>@log.Action</td>
                <td>@log.EntityName</td>
                <td>@(log.EmployeeId?.ToString() ?? "-")</td>
                <td>@(log.BranchId?.ToString() ?? "-")</td>
            </tr>
        }

        </tbody>
    </table>
</div>